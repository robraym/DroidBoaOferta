<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/row_monitor"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_row_pressed"
    android:gravity="center_vertical"
    android:minHeight="70dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="6dp"
    android:paddingEnd="8dp"
    android:paddingBottom="6dp">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_icon_circle"
        android:contentDescription="@string/dashboard_status_active"
        android:padding="8dp"
        android:src="@drawable/ic_monitor_percent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_monitor_status_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_status_choose_groups"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text_monitor_status_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:maxLines="2"
            android:text="@string/dashboard_status_choose_groups_summary"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/button_monitor_toggle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_button_inline"
        android:contentDescription="@string/action_pause"
        android:padding="9dp"
        android:scaleType="center"
        android:src="@drawable/ic_pause"
        android:visibility="gone" />
</LinearLayout>
