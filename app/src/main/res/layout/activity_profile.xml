<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="0dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/button_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_secondary"
                android:gravity="center"
                android:text="@string/icon_back"
                android:textColor="@color/text_primary"
                android:textSize="27sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/profile_screen_title"
                android:textColor="@color/text_primary"
                android:textSize="25sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_telegram_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_compact"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="84dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="10dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/text_profile_avatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_profile_avatar"
                android:gravity="center"
                android:text="@string/icon_telegram_letter"
                android:textColor="@color/button_text"
                android:textSize="25sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/profile_telegram_disconnected"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_profile_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/profile_telegram_disconnected_summary"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/text_profile_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/dashboard_telegram_starting"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/image_account_chevron"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_button_inline"
                android:contentDescription="@string/action_change"
                android:padding="8dp"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_compact"
            android:orientation="vertical"
            android:padding="6dp">

            <include layout="@layout/row_profile_theme" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="8dp"
                android:background="@color/divider" />

            <include layout="@layout/row_profile_alert_sound" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="8dp"
                android:background="@color/divider" />

            <include layout="@layout/row_profile_monitor" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="8dp"
                android:background="@color/divider" />

            <include layout="@layout/row_profile_sync" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="8dp"
                android:background="@color/divider" />

            <include layout="@layout/row_profile_errors" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="8dp"
                android:background="@color/divider" />

            <include layout="@layout/row_profile_terms" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="60dp"
                android:layout_marginEnd="8dp"
                android:background="@color/divider" />

            <include layout="@layout/row_profile_logout" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_app_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/profile_app_version_placeholder"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
