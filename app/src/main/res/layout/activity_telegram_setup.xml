<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/button_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center"
            android:text="@string/icon_back"
            android:textColor="@color/text_primary"
            android:textSize="27sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/telegram_setup_screen_title"
            android:textColor="@color/text_primary"
            android:textSize="25sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="28dp"
        android:text="@string/telegram_choose_groups_short"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/section_telegram_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_card_compact"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/text_telegram_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/telegram_status_connecting"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/text_telegram_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/telegram_wait_message"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/input_authentication"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:hint="@string/telegram_phone_hint"
            android:inputType="phone"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/row_phone_input"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/button_country_picker"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:ellipsize="end"
                android:focusable="true"
                android:gravity="center_vertical"
                android:maxWidth="170dp"
                android:minWidth="118dp"
                android:paddingStart="14dp"
                android:paddingEnd="10dp"
                android:text="@string/telegram_default_country"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:singleLine="true" />

            <View
                android:layout_width="1dp"
                android:layout_height="26dp"
                android:background="@color/input_border" />

            <EditText
                android:id="@+id/input_phone_number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:autofillHints="phoneNumber"
                android:background="@android:color/transparent"
                android:hint="@string/telegram_local_phone_hint"
                android:importantForAutofill="yes"
                android:inputType="phone"
                android:maxLength="24"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />
        </LinearLayout>

        <Button
            android:id="@+id/button_continue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/action_continue"
            android:textAllCaps="false"
            android:textColor="@color/button_text"
            android:textSize="16sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/button_receive_sms"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_secondary"
            android:text="@string/telegram_receive_sms"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:id="@+id/spacer_telegram_login"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ScrollView
        android:id="@+id/scroll_groups"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="13dp"
        android:layout_marginEnd="12dp"
        android:layout_weight="1"
        android:background="@drawable/bg_card_compact"
        android:clipToPadding="false"
        android:padding="6dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/container_groups"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/search_groups_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="13dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@string/search_hint"
            android:src="@drawable/ic_search" />

        <EditText
            android:id="@+id/input_search_groups"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="@string/search_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="18sp" />
    </LinearLayout>

    <include layout="@layout/view_bottom_navigation" />
</LinearLayout>
