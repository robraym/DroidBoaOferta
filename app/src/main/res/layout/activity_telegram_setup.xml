<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="4dp"
        android:paddingEnd="18dp">

        <TextView
            android:id="@+id/button_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center"
            android:text="@string/icon_back"
            android:textColor="@color/text_primary"
            android:textSize="27sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/telegram_setup_screen_title"
            android:textColor="@color/text_primary"
            android:textSize="25sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="20dp"
        android:text="@string/telegram_choose_groups_short"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <LinearLayout
        android:id="@+id/section_telegram_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/text_telegram_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/telegram_status_connecting"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/text_telegram_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/telegram_wait_message"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/input_authentication"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:hint="@string/telegram_phone_hint"
            android:importantForAutofill="no"
            android:inputType="phone"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:visibility="gone" />

        <Button
            android:id="@+id/button_continue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/action_continue"
            android:textAllCaps="false"
            android:textColor="@color/button_text"
            android:textSize="16sp"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_groups"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/container_groups"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/button_save_groups"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_button_primary"
        android:text="@string/action_save_groups"
        android:textAllCaps="false"
        android:textColor="@color/button_text"
        android:textSize="16sp"
        android:visibility="gone" />
</LinearLayout>
