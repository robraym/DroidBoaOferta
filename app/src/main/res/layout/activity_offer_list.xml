<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="0dp"
    android:paddingEnd="16dp"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/button_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_secondary"
            android:gravity="center"
            android:text="@string/icon_back"
            android:textColor="@color/text_primary"
            android:textSize="27sp" />

        <TextView
            android:id="@+id/text_screen_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="25sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/button_header_action"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_inline"
            android:contentDescription="@string/action_restore_all_offers"
            android:padding="9dp"
            android:scaleType="center"
            android:src="@drawable/ic_restore"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/container_offers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_compact"
            android:orientation="vertical"
            android:padding="6dp" />
    </ScrollView>
</LinearLayout>
